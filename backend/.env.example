# Embedding và generation đều chạy cục bộ bằng Ollama; không cần API key.
# Cài model bằng: ollama pull bge-m3; ollama pull qwen3:4b

APP_NAME=SLaw RAG API
APP_VERSION=1.1.0
DEBUG=true
LOG_LEVEL=INFO
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_RETRY_COUNT=3
OLLAMA_RETRY_DELAY_SECONDS=2
EMBEDDING_MODEL=bge-m3
OLLAMA_GENERATION_MODEL=qwen3:4b
EMBEDDING_BATCH_SIZE=16
GENERATION_MAX_TOKENS=1000
GENERATION_TEMPERATURE=0.2

SQLITE_PATH=data/slaw_ollama.db
CHROMA_PERSIST_DIR=data/chroma_ollama
CHROMA_COLLECTION_NAME=slaw_documents_bge_m3_v1
UPLOAD_TEMP_DIR=data/tmp

SESSION_TTL_MINUTES=1440
SESSION_CLEANUP_INTERVAL_SECONDS=300
MAX_SESSION_DOCUMENTS=5
MAX_FILE_SIZE_MB=10
CHUNK_SIZE_CHARS=2500
CHUNK_OVERLAP_CHARS=250
DEFAULT_TOP_K=5
MAX_TOP_K=20
MIN_SIMILARITY=0.20
HISTORY_MESSAGE_LIMIT=8
