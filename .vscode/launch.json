{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "SLaw: Backend FastAPI",
      "type": "debugpy",
      "request": "launch",
      "python": "${command:python.interpreterPath}",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "SLaw: Frontend Next.js",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "SLaw: Backend + Frontend",
      "configurations": ["SLaw: Backend FastAPI", "SLaw: Frontend Next.js"],
      "stopAll": true
    }
  ]
}
