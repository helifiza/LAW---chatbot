{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Ollama: check local models",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File .\\scripts\\check-ollama.ps1",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "Backend: install",
      "type": "process",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "pip", "install", "-r", "requirements-dev.txt"],
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    },
    {
      "label": "Backend: tests",
      "type": "process",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "pytest"],
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Frontend: install",
      "type": "shell",
      "command": "npm ci",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "Frontend: lint",
      "type": "shell",
      "command": "npm run lint",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "Frontend: build",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "problemMatcher": ["$tsc"]
    }
  ]
}
